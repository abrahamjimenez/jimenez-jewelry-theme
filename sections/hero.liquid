<div
  class="hero full-width"
  style="--overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }}; --min-height: {{ section.settings.min_height }}vh;"
>
  {%- if section.settings.image -%}
    <div class="hero__image">
      {{ section.settings.image | image_url: width: 2400 | image_tag: loading: 'eager', fetchpriority: 'high', class: 'hero__img', alt: section.settings.heading }}
    </div>
  {%- else -%}
    <div class="hero__image hero__image--placeholder">
      {{ 'lifestyle-1' | placeholder_svg_tag: 'hero__placeholder' }}
    </div>
  {%- endif -%}

  <div class="hero__overlay"></div>

  <div class="hero__content hero__content--{{ section.settings.content_alignment }}">
    {%- if section.settings.subtitle != blank -%}
      <span class="hero__subtitle">{{ section.settings.subtitle }}</span>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="hero__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="hero__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- if section.settings.cta_text != blank -%}
      <div class="hero__cta">
        <a href="{{ section.settings.cta_url | default: routes.collections_url }}" class="btn btn--outline-light">
          {{ section.settings.cta_text }}
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .hero {
    position: relative;
    min-height: var(--min-height, 85vh);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero__image {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__image img,
  .hero__image svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__image--placeholder svg {
    opacity: 0.4;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, var(--overlay-opacity, 0.3));
    z-index: 1;
  }

  .hero__content {
    position: relative;
    z-index: 2;
    color: #fff;
    padding: 4rem var(--page-margin);
    max-width: min(800px, 100%);
  }

  .hero__content--left {
    text-align: left;
    align-self: flex-end;
    padding-bottom: 6rem;
    margin-left: 0;
    margin-right: auto;
  }

  .hero__content--center {
    text-align: center;
    margin: 0 auto;
  }

  .hero__content--right {
    text-align: right;
    align-self: flex-end;
    padding-bottom: 6rem;
    margin-left: auto;
    margin-right: 0;
  }

  .hero__subtitle {
    display: block;
    font-size: 0.6875rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
    opacity: 0.85;
  }

  .hero__heading {
    font-size: clamp(2.75rem, 7vw, 5.5rem);
    font-family: var(--font-heading--family, var(--font-primary--family));
    font-weight: 400;
    line-height: 1.05;
    margin-bottom: 1.25rem;
    color: #fff;
  }

  .hero__subheading {
    font-size: 1rem;
    line-height: 1.7;
    opacity: 0.88;
    margin-bottom: 2.5rem;
    max-width: 480px;
  }

  .hero__content--center .hero__subheading {
    margin-left: auto;
    margin-right: auto;
  }

  .hero__cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero__content--center .hero__cta {
    justify-content: center;
  }

  .hero__content--right .hero__cta {
    justify-content: flex-end;
  }

  @media (max-width: 767px) {
    .hero__content--left,
    .hero__content--right {
      text-align: center;
      padding-bottom: 4rem;
      margin: 0 auto;
    }

    .hero__content--left .hero__cta,
    .hero__content--right .hero__cta {
      justify-content: center;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:labels.hero_image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "t:labels.overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 30
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "t:labels.section_title",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 85
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "t:labels.alignment",
      "options": [
        { "value": "left", "label": "t:options.alignment.left" },
        { "value": "center", "label": "t:options.alignment.center" },
        { "value": "right", "label": "t:options.alignment.right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "t:general.content"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "t:labels.subtitle",
      "default": "Jimenez Jewelry"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.title",
      "default": "Handcrafted earrings"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:labels.body_text",
      "default": "Each piece is made with care and intention, designed to be worn for a lifetime."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "t:labels.cta_text",
      "default": "Shop collection"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "t:labels.cta_url"
    }
  ],
  "presets": [
    {
      "name": "t:general.hero"
    }
  ]
}
{% endschema %}
