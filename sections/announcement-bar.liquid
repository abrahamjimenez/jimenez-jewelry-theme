{%- if section.settings.show_announcement and section.settings.text != blank -%}
  <div class="announcement-bar full-width">
    <p class="announcement-bar__text">{{ section.settings.text }}</p>
  </div>
{%- endif -%}

{% stylesheet %}
  .announcement-bar {
    background-color: var(--color-foreground);
    color: var(--color-background);
    text-align: center;
    padding: 0.625rem var(--page-margin);
  }

  .announcement-bar__text {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    margin: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.announcement_bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "t:labels.show_announcement",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "t:labels.announcement_text",
      "default": "Free shipping on orders over $75 · Handcrafted with love"
    }
  ]
}
{% endschema %}
