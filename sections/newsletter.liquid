<div class="newsletter full-width" style="--newsletter-bg: {{ section.settings.background_color }};">
  <div class="newsletter__inner">
    <div class="newsletter__content">
      {%- if section.settings.subtitle != blank -%}
        <span class="newsletter__subtitle">{{ section.settings.subtitle }}</span>
      {%- endif -%}

      {%- if section.settings.title != blank -%}
        <h2 class="newsletter__title">{{ section.settings.title }}</h2>
      {%- endif -%}

      {%- if section.settings.body_text != blank -%}
        <p class="newsletter__body">{{ section.settings.body_text }}</p>
      {%- endif -%}

      {%- if section.settings.show_discount_badge and section.settings.discount_badge != blank -%}
        <p class="newsletter__badge">{{ section.settings.discount_badge }}</p>
      {%- endif -%}
    </div>

    <div class="newsletter__form-wrapper">
      {% form 'customer', class: 'newsletter__form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">

        {%- if form.posted_successfully? -%}
          <p class="newsletter__success">{{ 'newsletter.success' | t }}</p>
        {%- else -%}
          <div class="newsletter__input-group">
            <label class="visually-hidden" for="newsletter-email">{{ section.settings.email_placeholder }}</label>
            <input
              type="email"
              id="newsletter-email"
              name="contact[email]"
              class="newsletter__input"
              placeholder="{{ section.settings.email_placeholder }}"
              required
              autocomplete="email"
            >
            <button type="submit" class="btn btn--dark newsletter__btn">
              {{ section.settings.submit_text }}
            </button>
          </div>

          {%- if form.errors -%}
            <p class="newsletter__error">{{ form.errors | default_errors }}</p>
          {%- endif -%}
        {%- endif -%}
      {% endform %}
    </div>
  </div>
</div>

{% stylesheet %}
  .newsletter {
    background-color: var(--newsletter-bg, var(--color-surface));
    padding: 5rem var(--page-margin);
  }

  .newsletter__inner {
    max-width: var(--page-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }

  .newsletter__content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .newsletter__subtitle {
    font-size: 0.6875rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .newsletter__title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1.15;
  }

  .newsletter__body {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--color-muted, #8c8680);
    max-width: 480px;
  }

  .newsletter__badge {
    display: inline-flex;
    align-self: flex-start;
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    background-color: var(--color-accent);
    color: #fff;
    padding: 0.375rem 0.875rem;
  }

  .newsletter__input-group {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .newsletter__input {
    width: 100%;
    padding: 0.875rem 1.25rem;
    background-color: var(--color-background);
    border: 1px solid var(--color-border);
    color: var(--color-foreground);
    font-size: 0.875rem;
    outline: none;
    transition: border-color 0.2s ease;
  }

  .newsletter__input:focus {
    border-color: var(--color-foreground);
  }

  .newsletter__input::placeholder {
    color: var(--color-muted, #8c8680);
  }

  .newsletter__btn {
    width: 100%;
  }

  .newsletter__success {
    font-size: 0.9375rem;
    color: var(--color-accent);
    padding: 1rem 0;
  }

  .newsletter__error {
    font-size: 0.8125rem;
    color: #c0392b;
    margin-top: 0.5rem;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }

  @media (min-width: 768px) {
    .newsletter__inner {
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
    }

    .newsletter__input-group {
      flex-direction: row;
    }

    .newsletter__input {
      flex: 1;
    }

    .newsletter__btn {
      width: auto;
      white-space: nowrap;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.newsletter",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "t:labels.background",
      "default": "#f0ece5"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "t:labels.subtitle",
      "default": "Stay connected"
    },
    {
      "type": "text",
      "id": "title",
      "label": "t:labels.title",
      "default": "Join the Jimenez family"
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "t:labels.body_text",
      "default": "Subscribe for new arrivals, exclusive offers, and the stories behind our pieces."
    },
    {
      "type": "checkbox",
      "id": "show_discount_badge",
      "label": "t:labels.show_discount_badge",
      "default": true
    },
    {
      "type": "text",
      "id": "discount_badge",
      "label": "t:labels.discount_badge",
      "default": "Get 10% off your first order"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "t:labels.email_placeholder",
      "default": "Your email address"
    },
    {
      "type": "text",
      "id": "submit_text",
      "label": "t:labels.submit_text",
      "default": "Subscribe"
    }
  ],
  "presets": [
    {
      "name": "t:general.newsletter"
    }
  ]
}
{% endschema %}
