<header class="header full-width">
  <div class="header__inner">
    <div class="header__left">
      <details class="header__mobile-menu">
        <summary class="header__hamburger" aria-label="Menu">
          <span></span>
          <span></span>
          <span></span>
        </summary>
        <div class="header__mobile-nav">
          {% for link in section.settings.menu.links %}
            <a class="header__mobile-link" href="{{ link.url }}">{{ link.title }}</a>
          {% endfor %}
        </div>
      </details>
    </div>

    <div class="header__logo">
      <a href="{{ routes.root_url }}" class="header__logo-link">
        <span class="header__logo-name">{{ shop.name }}</span>
      </a>
    </div>

    <nav class="header__nav" aria-label="Main navigation">
      {% for link in section.settings.menu.links %}
        <a class="header__nav-link" href="{{ link.url }}">{{ link.title }}</a>
      {% endfor %}
    </nav>

    <div class="header__icons">
      {% if shop.customer_accounts_enabled %}
        <shopify-account menu="{{ section.settings.customer_account_menu }}" class="header__icon-btn">
          {{ 'icon-account.svg' | inline_asset_content }}
        </shopify-account>
      {% endif %}

      <a href="{{ routes.cart_url }}" class="header__icon-btn header__cart-link" aria-label="Cart">
        {{ 'icon-cart.svg' | inline_asset_content }}
        {%- if cart.item_count > 0 -%}
          <span class="header__cart-count">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
    </div>
  </div>
</header>

{% stylesheet %}
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-background);
    border-bottom: 1px solid var(--color-border);
  }

  .header__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: 4.5rem;
    padding: 0 var(--page-margin);
    max-width: var(--page-width);
    margin: 0 auto;
    width: 100%;
  }

  .header__logo {
    grid-column: 2;
    text-align: center;
  }

  .header__logo-link {
    text-decoration: none;
    color: var(--color-foreground);
  }

  .header__logo-name {
    font-family: var(--font-heading--family, var(--font-primary--family));
    font-size: 1.25rem;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .header__nav {
    display: none;
    gap: 2rem;
    align-items: center;
    grid-column: 2;
  }

  .header__nav-link {
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-foreground);
    position: relative;
    padding-bottom: 2px;
  }

  .header__nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background-color: var(--color-accent);
    transition: width 0.25s ease;
  }

  .header__nav-link:hover::after {
    width: 100%;
  }

  .header__left {
    display: flex;
    align-items: center;
  }

  .header__icons {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 1rem;
  }

  .header__icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    color: var(--color-foreground);
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
  }

  .header__icon-btn svg {
    width: 1.375rem;
    height: 1.375rem;
  }

  .header__cart-count {
    position: absolute;
    top: -0.375rem;
    right: -0.5rem;
    background-color: var(--color-accent);
    color: #fff;
    font-size: 0.625rem;
    font-weight: 600;
    line-height: 1;
    min-width: 1.125rem;
    height: 1.125rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 0.2rem;
  }

  .header__hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    list-style: none;
    padding: 0.25rem;
  }

  .header__hamburger::-webkit-details-marker {
    display: none;
  }

  .header__hamburger span {
    display: block;
    width: 1.375rem;
    height: 1px;
    background-color: var(--color-foreground);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .header__mobile-menu[open] .header__hamburger span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }

  .header__mobile-menu[open] .header__hamburger span:nth-child(2) {
    opacity: 0;
  }

  .header__mobile-menu[open] .header__hamburger span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  .header__mobile-nav {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background-color: var(--color-background);
    border-bottom: 1px solid var(--color-border);
    padding: 1.5rem var(--page-margin);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    z-index: 99;
  }

  .header__mobile-link {
    font-size: 0.875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-foreground);
  }

  @media (min-width: 768px) {
    .header__inner {
      grid-template-columns: 1fr auto 1fr;
    }

    .header__hamburger {
      display: none;
    }

    .header__nav {
      display: flex;
      grid-column: 2;
    }

    .header__logo {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
    }

    .header__inner {
      grid-template-columns: 1fr 1fr 1fr;
      position: relative;
    }

    .header__left {
      display: none;
    }

    .header__nav {
      justify-content: flex-start;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
