<footer class="footer full-width">
  <div class="footer__inner">
    <div class="footer__brand">
      <a href="{{ routes.root_url }}" class="footer__logo">{{ shop.name }}</a>
      {%- if section.settings.tagline != blank -%}
        <p class="footer__tagline">{{ section.settings.tagline }}</p>
      {%- endif -%}

      {%- if section.settings.show_social -%}
        <div class="footer__social">
          {%- if section.settings.social_instagram != blank -%}
            <a href="{{ section.settings.social_instagram }}" class="footer__social-link" aria-label="Instagram" target="_blank" rel="noopener">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
              </svg>
            </a>
          {%- endif -%}
          {%- if section.settings.social_facebook != blank -%}
            <a href="{{ section.settings.social_facebook }}" class="footer__social-link" aria-label="Facebook" target="_blank" rel="noopener">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
              </svg>
            </a>
          {%- endif -%}
          {%- if section.settings.social_pinterest != blank -%}
            <a href="{{ section.settings.social_pinterest }}" class="footer__social-link" aria-label="Pinterest" target="_blank" rel="noopener">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2C6.48 2 2 6.48 2 12c0 4.24 2.65 7.86 6.39 9.29-.09-.78-.17-1.98.04-2.83.18-.76 1.22-5.18 1.22-5.18s-.31-.62-.31-1.55c0-1.45.84-2.53 1.89-2.53.89 0 1.32.67 1.32 1.47 0 .9-.57 2.24-.87 3.48-.25 1.04.52 1.88 1.54 1.88 1.85 0 3.09-2.37 3.09-5.18 0-2.14-1.44-3.64-3.5-3.64-2.39 0-3.79 1.79-3.79 3.64 0 .72.28 1.49.62 1.91.07.08.08.15.06.23-.06.27-.21.84-.24.96-.04.15-.13.19-.3.11-1.12-.52-1.82-2.16-1.82-3.47 0-2.82 2.05-5.41 5.91-5.41 3.1 0 5.51 2.21 5.51 5.16 0 3.08-1.94 5.55-4.63 5.55-.9 0-1.75-.47-2.04-1.02l-.56 2.08c-.2.78-.74 1.76-1.1 2.35.83.26 1.71.4 2.62.4 5.52 0 10-4.48 10-10S17.52 2 12 2z"/>
              </svg>
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    <div class="footer__nav">
      {% for link in section.settings.menu.links %}
        <a class="footer__nav-link" href="{{ link.url }}">{{ link.title }}</a>
      {% endfor %}
    </div>

    <div class="footer__bottom">
      <p class="footer__copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name | link_to: routes.root_url }}.
      </p>

      {%- if section.settings.show_payment_icons -%}
        <div class="footer__payment">
          {% for type in shop.enabled_payment_types %}
            {{ type | payment_type_svg_tag }}
          {% endfor %}
        </div>
      {%- endif -%}
    </div>
  </div>
</footer>

{% stylesheet %}
  .footer {
    background-color: var(--color-foreground);
    color: var(--color-background);
    margin-top: auto;
  }

  .footer__inner {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 4rem var(--page-margin) 2rem;
  }

  .footer__brand {
    margin-bottom: 3rem;
    text-align: center;
  }

  .footer__logo {
    display: inline-block;
    font-family: var(--font-heading--family, var(--font-primary--family));
    font-size: 1.375rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-background);
    margin-bottom: 0.75rem;
  }

  .footer__tagline {
    font-size: 0.8125rem;
    letter-spacing: 0.06em;
    opacity: 0.65;
    margin-bottom: 1.5rem;
  }

  .footer__social {
    display: flex;
    justify-content: center;
    gap: 1.25rem;
  }

  .footer__social-link {
    color: var(--color-background);
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }

  .footer__social-link:hover {
    opacity: 1;
  }

  .footer__nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem 2rem;
    margin-bottom: 3rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  .footer__nav-link {
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-background);
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }

  .footer__nav-link:hover {
    opacity: 1;
  }

  .footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer__copyright {
    font-size: 0.75rem;
    opacity: 0.5;
  }

  .footer__copyright a {
    color: inherit;
    text-decoration: none;
  }

  .footer__payment {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .footer__payment svg {
    height: 1.75rem;
    width: auto;
    opacity: 0.6;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.footer",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "t:labels.tagline",
      "default": "Handcrafted earrings, made with love"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "header",
      "content": "t:labels.show_social"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "t:labels.show_social",
      "default": true
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "t:labels.social_instagram"
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "t:labels.social_facebook"
    },
    {
      "type": "url",
      "id": "social_pinterest",
      "label": "t:labels.social_pinterest"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "t:labels.show_payment_icons",
      "default": true
    }
  ]
}
{% endschema %}
